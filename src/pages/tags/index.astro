---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { buildTagSummary } from "../../utils/tags";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const tagSummary = buildTagSummary(posts);
---

<BaseLayout title="devjune.dev | Tags" description="Tag archive index">
  <section class="hero">
    <h1>Tags</h1>
    <p>Browse notes through focused backend keywords.</p>
  </section>

  <ul class="post-list" style="margin-top: 1rem;">
    {tagSummary.map(({ tag, count }) => (
      <li class="card category-card-row">
        <a class="badge badge--topic badge--topic-tag" href={`/tags/${tag}/`}>
          <span>#{tag}</span>
          <strong>{count}</strong>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
