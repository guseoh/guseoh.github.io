---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import Pagination from "../../components/Pagination.astro";
import { getCollection } from "astro:content";

const PAGE_SIZE = 5;

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const pagePosts = posts.slice(0, PAGE_SIZE);
const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
---

<BaseLayout title="guseo.dev | Blog" description="전체 게시글 목록">
  <section class="hero">
    <h1>Blog</h1>
    <p>기술 메모, 삽질 기록, 실무 적용 노트를 모아둔 아카이브입니다.</p>
  </section>

  <ul class="post-list" style="margin-top: 1rem;">
    {pagePosts.map((post) => (
      <li>
        <PostCard post={post} />
      </li>
    ))}
  </ul>

  <Pagination currentPage={1} totalPages={totalPages} basePath="/blog" />
</BaseLayout>
