---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostComments from "../../components/PostComments.astro";
import { normalizeCategory } from "../../utils/categories";
import { normalizeTag } from "../../utils/tags";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content, headings } = await render(post);
const categoryName = post.data.category?.trim() || "Uncategorized";
const categorySlug = normalizeCategory(categoryName);
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<BaseLayout title={`${post.data.title} | guseo.dev`} description={post.data.description}>
  <div class="post-view">
    <article class="post">
      <header class="post__header">
        <h1>{post.data.title}</h1>
        <p class="meta">
          <span>{post.data.pubDate.toLocaleDateString("ko-KR")}</span>
          <span data-post-view-count={post.slug}>Views 0</span>
          {post.data.updatedDate && <span>Updated: {post.data.updatedDate.toLocaleDateString("ko-KR")}</span>}
        </p>
        <div class="meta">
          <a class="tag tag--category" href={`/categories/${categorySlug}/`}>{categoryName}</a>
          {post.data.tags.map((tag) => (
            <a class="tag" href={`/tags/${normalizeTag(tag)}/`}>#{tag}</a>
          ))}
        </div>
      </header>

      <Content />

      <PostComments />
    </article>

    {
      tocHeadings.length > 0 && (
        <aside class="post-toc" aria-label="Document table of contents">
          <p class="post-toc__title">On This Page</p>
          <ul class="post-toc__list">
            {tocHeadings.map((heading) => (
              <li class:list={["post-toc__item", `depth-${heading.depth}`]}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
  </div>
</BaseLayout>