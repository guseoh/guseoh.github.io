---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildCategorySummary } from "../utils/categories";
import ArchiveHero from "../components/home/ArchiveHero.astro";
import LatestPosts from "../components/home/LatestPosts.astro";
import TopicIndex from "../components/home/TopicIndex.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const latestPosts = posts.slice(0, 12);
const categorySummary = buildCategorySummary(posts);
---

<BaseLayout
  title="guseo.dev | Tech Notes Archive"
  description="Java, Spring, Backend 기술 기록 아카이브"
  minimalHome={true}
>
  <ArchiveHero />
  <LatestPosts posts={latestPosts} />
  <TopicIndex categories={categorySummary} />
</BaseLayout>
