---
import type { CategorySummary } from "../../utils/categories";

interface Props {
  categories: CategorySummary[];
}

const { categories } = Astro.props as Props;
---

<section class="home-section" aria-label="Categories">
  <div class="home-section__head home-section__head--inline">
    <h2 class="home-section__title">Categories</h2>
    <a class="home-section__link" href="/categories/">All categories</a>
  </div>

  {categories.length === 0 ? (
    <p class="section-empty">카테고리가 없습니다.</p>
  ) : (
    <div class="category-chip-list">
      {categories.map(({ slug, name, count }) => (
        <a class="category-chip" href={`/categories/${slug}/`}>
          <span>{name}</span>
          <strong>{count}</strong>
        </a>
      ))}
    </div>
  )}
</section>
