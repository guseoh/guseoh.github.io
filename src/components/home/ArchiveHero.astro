---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "guseo.dev",
  description = "Java / Spring / Backend 학습 기록을 정리하는 개인 기술 아카이브입니다."
} = Astro.props as Props;
---

<section class="archive-hero archive-hero--simple" aria-label="Blog intro">
  <h1>{title}</h1>
  <p>{description}</p>
</section>
