---
import type { CollectionEntry } from "astro:content";
import PostMetaBadges from "../PostMetaBadges.astro";
import { formatPostDate, getReadingTime } from "../../utils/posts";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props as Props;
---

{posts.length > 0 && (
  <section class="home-section" aria-label="Featured posts">
    <div class="home-section__head">
      <h2 class="home-section__title">Featured Posts</h2>
      <p class="home-section__description">프로젝트와 백엔드 역량을 보여주는 대표 기록입니다.</p>
    </div>

    <div class="featured-grid">
      {posts.map((post, index) => (
        <article class:list={["card", "featured-card", index === 0 && "featured-card--lead"]}>
          <p class="featured-card__label">Featured</p>
          <h3><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h3>
          <p class="featured-card__description">{post.data.description}</p>

          <div class="featured-card__meta">
            <time datetime={post.data.date.toISOString()}>{formatPostDate(post.data.date)}</time>
            <span aria-hidden="true">·</span>
            <span>{getReadingTime(post)}</span>
          </div>

          <PostMetaBadges category={post.data.category} tags={post.data.tags} maxTags={4} />
        </article>
      ))}
    </div>
  </section>
)}
