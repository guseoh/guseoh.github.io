---
import type { CollectionEntry } from "astro:content";
import { normalizeCategory } from "../../utils/categories";
import { formatPostDate, getReadingTime } from "../../utils/posts";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props as Props;
---

<section class="home-section" aria-label="Latest posts">
  <div class="home-section__head home-section__head--inline">
    <h2 class="home-section__title">Latest Posts</h2>
    <a class="home-section__link" href="/blog/">All posts</a>
  </div>

  {posts.length === 0 ? (
    <p class="section-empty">아직 게시글이 없습니다.</p>
  ) : (
    <ul class="latest-list">
      {posts.map((post) => {
        const categoryName = post.data.category?.trim() || "미분류";
        const readingTime = getReadingTime(post);
        return (
          <li class="latest-item">
            <a class="latest-item__title" href={`/blog/${post.slug}/`}>{post.data.title}</a>
            <p class="latest-item__meta">
              <time datetime={post.data.date.toISOString()}>{formatPostDate(post.data.date)}</time>
              <span aria-hidden="true">·</span>
              <a href={`/categories/${normalizeCategory(categoryName)}/`}>{categoryName}</a>
              <span aria-hidden="true">·</span>
              <span>{readingTime}</span>
            </p>
            <p class="latest-item__summary">{post.data.description}</p>
          </li>
        );
      })}
    </ul>
  )}
</section>
