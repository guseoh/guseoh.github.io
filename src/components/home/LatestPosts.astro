---
import type { CollectionEntry } from "astro:content";
import PostCard from "../PostCard.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props as Props;
---

<section class="home-section" aria-label="Latest posts">
  <div class="home-section__head home-section__head--inline">
    <div>
      <h2 class="home-section__title">Latest Posts</h2>
      <p class="home-section__description">Recent updates in card layout for faster scanning.</p>
    </div>
    <a class="home-section__link" href="/blog/">View all</a>
  </div>

  {posts.length === 0 ? (
    <p class="section-empty">No post yet.</p>
  ) : (
    <ul class="post-grid post-grid--latest">
      {posts.map((post) => (
        <li>
          <PostCard post={post} variant="latest" />
        </li>
      ))}
    </ul>
  )}
</section>
