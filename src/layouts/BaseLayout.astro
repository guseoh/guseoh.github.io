---
import "../styles/global.css";
import { getCollection } from "astro:content";
import { buildCategorySummary } from "../utils/categories";
import { buildTagSummary } from "../utils/tags";
import { SITE_DESCRIPTION, SITE_TITLE } from "../utils/posts";

interface Props {
  title?: string;
  description?: string;
  minimalHome?: boolean;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  minimalHome = false
} = Astro.props;

const posts = await getCollection("blog", ({ data }) => !data.draft);
const categorySummary = buildCategorySummary(posts);
const tagSummary = buildTagSummary(posts).slice(0, 18);

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const currentCategory = currentPath.startsWith("/categories/") ? currentPath.split("/")[2] ?? "" : "";
const currentTag = currentPath.startsWith("/tags/") ? currentPath.split("/")[2] ?? "" : "";

const sidebarLinks = [
  { href: "/blog", label: "Post" },
  { href: "/categories", label: "Categories" },
  { href: "/tags", label: "Tags" }
];

function isNavActive(href: string) {
  const normalizedHref = href.replace(/\/+$/, "");
  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
}
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored === "light" || stored === "dark" ? stored : systemDark ? "dark" : "light";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body class:list={[minimalHome && "page-home-simple"]}>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand" href="/">guseo.dev</a>

          <button
            id="theme-toggle"
            class="theme-toggle"
            type="button"
            aria-label="Toggle dark mode"
            data-theme="light"
          >
            <span class="theme-toggle__icon" aria-hidden="true">
              <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" role="img" aria-hidden="true">
                <path d="M20 14.25A8.25 8.25 0 0 1 9.75 4a8.26 8.26 0 1 0 10.25 10.25Z"></path>
              </svg>
              <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" role="img" aria-hidden="true">
                <circle cx="12" cy="12" r="3.6"></circle>
                <path d="M12 2.5v2.2M12 19.3v2.2M21.5 12h-2.2M4.7 12H2.5M18.7 5.3l-1.6 1.6M6.9 17.1l-1.6 1.6M18.7 18.7l-1.6-1.6M6.9 6.9L5.3 5.3"></path>
              </svg>
            </span>
            <span class="theme-toggle__label">Dark</span>
          </button>
        </div>
      </header>

      <div class:list={["site-layout", minimalHome && "site-layout--minimal"]}>
        {!minimalHome && (
          <>
            <button id="sidebar-open" class="sidebar-open" type="button" aria-label="Open sidebar" aria-controls="site-sidebar">
              <span></span>
              <span></span>
              <span></span>
            </button>

            <aside id="site-sidebar" class="site-sidebar" aria-label="Blog sidebar">
              <section class="sidebar-close-section" aria-label="Close menu section">
                <button id="sidebar-close" class="sidebar-close" type="button" aria-label="Close sidebar">X</button>
              </section>

              <section class="profile-card">
                <div class="profile-card__cover" aria-hidden="true"></div>
                <div class="profile-card__avatar" aria-hidden="true">G</div>
                <div class="profile-card__body">
                  <p class="profile-card__name">guseo.dev</p>
                  <p class="profile-card__bio">Java/Spring 백엔드 개발자 오지훈의 학습과 프로젝트 개선 기록</p>
                </div>
              </section>

              <form class="sidebar-search" action="/search/" method="get" aria-label="Search posts">
                <label class="sr-only" for="sidebar-search-input">Search</label>
                <input id="sidebar-search-input" name="q" type="search" placeholder="Search posts" />
                <button type="submit" aria-label="Run search">Go</button>
              </form>

              <nav class="sidebar-nav" aria-label="Primary links">
                {sidebarLinks.map(({ href, label }) => (
                  <a class:list={["sidebar-nav__item", isNavActive(href) && "is-active"]} href={href}>
                    {label}
                  </a>
                ))}
              </nav>

              <section class="category-panel" aria-label="Topic index">
                <div class="category-panel__header">
                  <h2>Topic Index</h2>
                  <a href="/categories/">All</a>
                </div>

                {categorySummary.length === 0 ? (
                  <p class="category-empty">No categories yet.</p>
                ) : (
                  <div class="topic-cloud" role="list">
                    {categorySummary.map(({ slug, name, count }) => (
                      <a class:list={["topic-pill", "topic-pill--category", currentCategory === slug && "is-active"]} href={`/categories/${slug}/`}>
                        <span>{name}</span>
                        <strong>{count}</strong>
                      </a>
                    ))}
                  </div>
                )}

                {tagSummary.length > 0 && (
                  <>
                    <p class="category-panel__subhead">Tags</p>
                    <div class="topic-cloud topic-cloud--tags" role="list">
                      {tagSummary.map(({ tag, count }) => (
                        <a class:list={["topic-pill", "topic-pill--tag", currentTag === tag && "is-active"]} href={`/tags/${tag}/`}>
                          <span>#{tag}</span>
                          <strong>{count}</strong>
                        </a>
                      ))}
                    </div>
                  </>
                )}
              </section>
            </aside>
          </>
        )}

        <div class="site-content">
          <main class="site-main">
            <slot />
          </main>
        </div>
      </div>
    </div>

    <script is:inline>
      (() => {
        const themeButton = document.getElementById("theme-toggle");
        if (themeButton instanceof HTMLButtonElement) {
          const label = themeButton.querySelector(".theme-toggle__label");

          const updateThemeButton = (theme) => {
            themeButton.dataset.theme = theme;

            if (label instanceof HTMLElement) {
              label.textContent = theme === "dark" ? "Light" : "Dark";
            }

            themeButton.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
          };

          const currentTheme = document.documentElement.getAttribute("data-theme") || "light";
          updateThemeButton(currentTheme);

          themeButton.addEventListener("click", () => {
            const now = document.documentElement.getAttribute("data-theme") || "light";
            const next = now === "dark" ? "light" : "dark";
            document.documentElement.setAttribute("data-theme", next);
            localStorage.setItem("theme", next);
            updateThemeButton(next);
          });
        }

        const shell = document.querySelector(".site-shell");
        const sidebarOpenButton = document.getElementById("sidebar-open");
        const sidebarCloseButton = document.getElementById("sidebar-close");

        if (
          shell instanceof HTMLElement &&
          sidebarOpenButton instanceof HTMLButtonElement &&
          sidebarCloseButton instanceof HTMLButtonElement
        ) {
          const SIDEBAR_KEY = "guseo:sidebar-collapsed";

          const applySidebarState = (collapsed) => {
            shell.classList.toggle("sidebar-collapsed", collapsed);
            sidebarOpenButton.setAttribute("aria-hidden", collapsed ? "false" : "true");
            sidebarCloseButton.setAttribute("aria-hidden", collapsed ? "true" : "false");
            sidebarOpenButton.setAttribute("aria-expanded", collapsed ? "false" : "true");
          };

          const initialCollapsed = localStorage.getItem(SIDEBAR_KEY) === "true";
          applySidebarState(initialCollapsed);

          sidebarOpenButton.addEventListener("click", () => {
            applySidebarState(false);
            localStorage.setItem(SIDEBAR_KEY, "false");
          });

          sidebarCloseButton.addEventListener("click", () => {
            applySidebarState(true);
            localStorage.setItem(SIDEBAR_KEY, "true");
          });
        }

        const sidebarSearchInput = document.getElementById("sidebar-search-input");
        if (sidebarSearchInput instanceof HTMLInputElement && window.location.pathname.startsWith("/search")) {
          sidebarSearchInput.value = new URLSearchParams(window.location.search).get("q") ?? "";
        }
      })();
    </script>
  </body>
</html>
