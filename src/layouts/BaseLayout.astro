---
import "../styles/global.css";
import { getCollection } from "astro:content";
import { buildTagSummary } from "../utils/tags";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "guseo.dev | GitHub Pages Blog",
  description = "Astro와 GitHub Pages로 운영하는 개인 기술 블로그"
} = Astro.props;

const posts = await getCollection("blog", ({ data }) => !data.draft);
const tagSummary = buildTagSummary(posts);
const postCount = posts.length;

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const currentTag = currentPath.startsWith("/tags/") ? currentPath.split("/")[2] ?? "" : "";

const sidebarLinks = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Posts" },
  { href: "/tags", label: "Tags" },
  { href: "/about", label: "About" }
];

function isNavActive(href: string) {
  if (href === "/") return currentPath === "/";
  const normalizedHref = href.replace(/\/+$/, "");
  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
}
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored === "light" || stored === "dark" ? stored : systemDark ? "dark" : "light";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand" href="/">guseo.dev</a>
          <button id="theme-toggle" class="theme-toggle" type="button" aria-label="다크모드 전환">
            🌙 Dark
          </button>
        </div>
      </header>

      <div class="site-layout">
        <aside class="site-sidebar" aria-label="블로그 사이드바">
          <section class="profile-card">
            <div class="profile-card__cover" aria-hidden="true"></div>
            <div class="profile-card__avatar" aria-hidden="true">G</div>
            <div class="profile-card__body">
              <p class="profile-card__name">guseo.dev</p>
              <p class="profile-card__bio">작게 만들고, 빠르게 기록합니다.</p>
            </div>
            <p class="profile-card__meta">ROOT ({postCount})</p>
          </section>

          <nav class="sidebar-nav" aria-label="주요 메뉴">
            {
              sidebarLinks.map(({ href, label }) => (
                <a class:list={["sidebar-nav__item", isNavActive(href) && "is-active"]} href={href}>
                  {label}
                </a>
              ))
            }
          </nav>

          <section class="category-panel" aria-label="카테고리 목록">
            <div class="category-panel__header">
              <h2>Categories</h2>
              <a href="/tags">All</a>
            </div>

            {
              tagSummary.length === 0 ? (
                <p class="category-empty">아직 카테고리가 없습니다.</p>
              ) : (
                <ul class="category-list">
                  {tagSummary.map(({ tag, count }) => (
                    <li>
                      <a class:list={["category-link", currentTag === tag && "is-active"]} href={`/tags/${tag}/`}>
                        <span>#{tag}</span>
                        <span>{count}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              )
            }
          </section>
        </aside>

        <div class="site-content">
          <main class="site-main">
            <slot />
          </main>

          <footer class="site-footer">
            <p>© {new Date().getFullYear()} guseo.dev · Built with Astro + GitHub Pages.</p>
          </footer>
        </div>
      </div>
    </div>

    <script is:inline>
      (() => {
        const button = document.getElementById("theme-toggle");
        if (!(button instanceof HTMLButtonElement)) return;

        const updateButton = (theme) => {
          button.textContent = theme === "dark" ? "☀️ Light" : "🌙 Dark";
          button.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
        };

        const current = document.documentElement.getAttribute("data-theme") || "light";
        updateButton(current);

        button.addEventListener("click", () => {
          const now = document.documentElement.getAttribute("data-theme") || "light";
          const next = now === "dark" ? "light" : "dark";
          document.documentElement.setAttribute("data-theme", next);
          localStorage.setItem("theme", next);
          updateButton(next);
        });
      })();
    </script>
  </body>
</html>
