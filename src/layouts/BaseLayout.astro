---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "guseo.dev | GitHub Pages Blog",
  description = "Astro와 GitHub Pages로 운영하는 개인 기술 블로그"
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand" href="/">guseo.dev</a>
          <nav class="nav" aria-label="Primary">
            <a href="/">Home</a>
            <a href="/blog">Blog</a>
            <a href="/tags">Tags</a>
            <a href="/about">About</a>
            <a href="/rss.xml">RSS</a>
          </nav>
        </div>
      </header>
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <p>© {new Date().getFullYear()} guseo.dev · Built with Astro + GitHub Pages.</p>
      </footer>
    </div>
  </body>
</html>
