---
import "../styles/global.css";
import { getCollection } from "astro:content";
import { buildCategorySummary } from "../utils/categories";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "guseo.dev | GitHub Pages Blog",
  description = "Personal tech blog built with Astro and GitHub Pages"
} = Astro.props;

const posts = await getCollection("blog", ({ data }) => !data.draft);
const categorySummary = buildCategorySummary(posts);
const postCount = posts.length;

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const currentCategory = currentPath.startsWith("/categories/") ? currentPath.split("/")[2] ?? "" : "";

const sidebarLinks = [
  { href: "/blog", label: "Posts" },
  { href: "/categories", label: "Categories" }
];

function isNavActive(href: string) {
  const normalizedHref = href.replace(/\/+$/, "");
  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
}
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored === "light" || stored === "dark" ? stored : systemDark ? "dark" : "light";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand" href="/">guseo.dev</a>
          <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode">
            Dark
          </button>
        </div>
      </header>

      <div class="site-layout">
        <button id="sidebar-open" class="sidebar-open" type="button" aria-label="Open sidebar" aria-controls="site-sidebar">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <aside id="site-sidebar" class="site-sidebar" aria-label="Blog sidebar">
          <button id="sidebar-close" class="sidebar-close" type="button" aria-label="Close sidebar">X</button>

          <section class="profile-card">
            <div class="profile-card__cover" aria-hidden="true"></div>
            <div class="profile-card__avatar" aria-hidden="true">G</div>
            <div class="profile-card__body">
              <p class="profile-card__name">guseo.dev</p>
              <p class="profile-card__bio">Build small, ship fast, keep notes.</p>
            </div>
            <p class="profile-card__meta">ROOT ({postCount})</p>
          </section>

          <section class="visit-panel" aria-label="Visit statistics">
            <div class="visit-panel__grid">
              <div>
                <p>Total</p>
                <strong id="visit-total">0</strong>
              </div>
              <div>
                <p>Today</p>
                <strong id="visit-today">0</strong>
              </div>
              <div>
                <p>Yesterday</p>
                <strong id="visit-yesterday">0</strong>
              </div>
            </div>
          </section>

          <form class="sidebar-search" action="/search/" method="get" aria-label="Search posts">
            <label class="sr-only" for="sidebar-search-input">Search</label>
            <input id="sidebar-search-input" name="q" type="search" placeholder="Search posts" />
            <button type="submit" aria-label="Run search">Go</button>
          </form>

          <nav class="sidebar-nav" aria-label="Primary links">
            {
              sidebarLinks.map(({ href, label }) => (
                <a class:list={[
                  "sidebar-nav__item",
                  isNavActive(href) && "is-active"
                ]} href={href}>
                  {label}
                </a>
              ))
            }
          </nav>

          <section class="category-panel" aria-label="Category list">
            <div class="category-panel__header">
              <h2>Categories ({postCount})</h2>
              <a href="/categories/">All</a>
            </div>

            {
              categorySummary.length === 0 ? (
                <p class="category-empty">No categories yet.</p>
              ) : (
                <ul class="category-list">
                  {categorySummary.map(({ slug, name, count }) => (
                    <li>
                      <a
                        class:list={[
                          "category-link",
                          currentCategory === slug && "is-active"
                        ]}
                        href={`/categories/${slug}/`}
                      >
                        <span>{name}</span>
                        <span>{count}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              )
            }
          </section>
        </aside>

        <div class="site-content">
          <main class="site-main">
            <slot />
          </main>

          <footer class="site-footer">
            <p>(c) {new Date().getFullYear()} guseo.dev - Built with Astro + GitHub Pages.</p>
          </footer>
        </div>
      </div>
    </div>

    <script is:inline>
      (() => {
        const themeButton = document.getElementById("theme-toggle");
        if (themeButton instanceof HTMLButtonElement) {
          const updateThemeButton = (theme) => {
            themeButton.textContent = theme === "dark" ? "Light" : "Dark";
            themeButton.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
          };

          const currentTheme = document.documentElement.getAttribute("data-theme") || "light";
          updateThemeButton(currentTheme);

          themeButton.addEventListener("click", () => {
            const now = document.documentElement.getAttribute("data-theme") || "light";
            const next = now === "dark" ? "light" : "dark";
            document.documentElement.setAttribute("data-theme", next);
            localStorage.setItem("theme", next);
            updateThemeButton(next);
          });
        }

        const shell = document.querySelector(".site-shell");
        const sidebarOpenButton = document.getElementById("sidebar-open");
        const sidebarCloseButton = document.getElementById("sidebar-close");

        if (
          shell instanceof HTMLElement &&
          sidebarOpenButton instanceof HTMLButtonElement &&
          sidebarCloseButton instanceof HTMLButtonElement
        ) {
          const SIDEBAR_KEY = "guseo:sidebar-collapsed";

          const applySidebarState = (collapsed) => {
            shell.classList.toggle("sidebar-collapsed", collapsed);
            sidebarOpenButton.setAttribute("aria-hidden", collapsed ? "false" : "true");
            sidebarCloseButton.setAttribute("aria-hidden", collapsed ? "true" : "false");
          };

          const initialCollapsed = localStorage.getItem(SIDEBAR_KEY) === "true";
          applySidebarState(initialCollapsed);

          sidebarOpenButton.addEventListener("click", () => {
            applySidebarState(false);
            localStorage.setItem(SIDEBAR_KEY, "false");
          });

          sidebarCloseButton.addEventListener("click", () => {
            applySidebarState(true);
            localStorage.setItem(SIDEBAR_KEY, "true");
          });
        }

        const VISIT_KEY = "guseo:visit-history:v2";
        const RESET_KEY = "guseo:visit-reset-v2";
        const LEGACY_VISIT_KEYS = ["guseo:visit-history:v1"];
        const VISIT_GATE_COOKIE = "guseo_visit_gate";
        const TWELVE_HOURS_MS = 12 * 60 * 60 * 1000;

        if (localStorage.getItem(RESET_KEY) !== "done") {
          for (const key of LEGACY_VISIT_KEYS) {
            localStorage.removeItem(key);
          }
          localStorage.removeItem(VISIT_KEY);
          localStorage.setItem(RESET_KEY, "done");
        }

        const toKey = (date) => {
          const year = date.getFullYear();
          const month = String(date.getMonth() + 1).padStart(2, "0");
          const day = String(date.getDate()).padStart(2, "0");
          return `${year}-${month}-${day}`;
        };

        const readHistory = () => {
          try {
            const raw = localStorage.getItem(VISIT_KEY);
            if (!raw) return {};
            const parsed = JSON.parse(raw);
            return parsed && typeof parsed === "object" ? parsed : {};
          } catch {
            return {};
          }
        };

        const readCookie = (name) => {
          const prefix = `${name}=`;
          const entries = document.cookie.split(";");

          for (const entry of entries) {
            const item = entry.trim();
            if (!item.startsWith(prefix)) continue;
            return decodeURIComponent(item.slice(prefix.length));
          }

          return "";
        };

        const writeCookie = (name, value, maxAgeSeconds) => {
          document.cookie = `${name}=${encodeURIComponent(value)}; path=/; max-age=${maxAgeSeconds}; samesite=lax`;
        };

        const history = readHistory();
        const now = new Date();
        const yesterday = new Date(now);
        yesterday.setDate(now.getDate() - 1);

        const todayKey = toKey(now);
        const yesterdayKey = toKey(yesterday);

        const currentTimestamp = Date.now();
        const gateRaw = readCookie(VISIT_GATE_COOKIE);
        const previousTimestamp = Number(gateRaw);
        const canCountVisit =
          !Number.isFinite(previousTimestamp) || previousTimestamp <= 0
            ? true
            : currentTimestamp - previousTimestamp >= TWELVE_HOURS_MS;

        if (canCountVisit) {
          history[todayKey] = (Number(history[todayKey]) || 0) + 1;
          writeCookie(VISIT_GATE_COOKIE, String(currentTimestamp), 60 * 60 * 24 * 365);
        }

        const keys = Object.keys(history).sort();
        while (keys.length > 400) {
          const oldKey = keys.shift();
          if (!oldKey) break;
          delete history[oldKey];
        }

        localStorage.setItem(VISIT_KEY, JSON.stringify(history));

        const total = Object.values(history).reduce((sum, count) => sum + (Number(count) || 0), 0);
        const todayCount = Number(history[todayKey]) || 0;
        const yesterdayCount = Number(history[yesterdayKey]) || 0;

        const writeMetric = (id, value) => {
          const target = document.getElementById(id);
          if (!target) return;
          target.textContent = value.toLocaleString("ko-KR");
        };

        writeMetric("visit-total", total);
        writeMetric("visit-today", todayCount);
        writeMetric("visit-yesterday", yesterdayCount);

        const sidebarSearchInput = document.getElementById("sidebar-search-input");
        if (sidebarSearchInput instanceof HTMLInputElement && window.location.pathname.startsWith("/search")) {
          sidebarSearchInput.value = new URLSearchParams(window.location.search).get("q") ?? "";
        }
      })();
    </script>
  </body>
</html>